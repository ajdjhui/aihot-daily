# AI HOT Daily Bot — 环境变量配置
# 复制此文件为 .env 并填入真实值（.env 不会被 git 提交）

# ── SMTP 邮件 ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587

# 发件人账号
SMTP_USER=your-email@example.com
SMTP_PASS=your-password-or-app-password

# 收件人
TO_EMAIL=recipient@example.com

# 发件人显示地址（可选，默认同 SMTP_USER）
# FROM_EMAIL=daily@example.com

# ── MySQL 数据库（可选，默认连本地 root@localhost:3306/aihot）──
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASS=your-mysql-password
# DB_NAME=aihot
